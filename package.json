{
  "name": "flux-transfer",
  "version": "0.1.5",
  "description": "Small, framework-agnostic file transfer engine with chunking, resume, retry and protocol adapters",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "docs/compatibility.md", "examples", "benchmarks", "README.md", "README_CN.md", "LICENSE"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "example": "npm run build && node examples/demo.mjs",
    "benchmark": "npm run build && node --expose-gc benchmarks/transfer-overhead.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run type-check && npm run test:coverage && npm run build"
  },
  "keywords": ["file-upload", "file-download", "chunk-upload", "resume-upload", "typescript"],
  "license": "MIT",
  "engines": { "node": ">=18.0.0" },
  "dependencies": { "spark-md5": "^3.0.2" },
  "devDependencies": {
    "@types/spark-md5": "^3.0.5",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
